<!-- ============================================================
     HERMES AGENT — Tool Definitions
     Generated by ASK (Agent Setup Kit)

     Tool definitions for the Hermes function calling system.
     These go inside <tools></tools> XML tags in the system prompt.

     Hermes uses OpenAI-compatible JSON schema format.
     The runtime auto-registers tools from its tool registry,
     but custom tools can be defined here for reference or
     for direct system prompt injection.

     Format reference:
       <tools>[...tool definitions...]</tools>

     Each tool call by the model:
       <tool_call>
       {"name": "tool_name", "arguments": {"key": "value"}}
       </tool_call>

     Each tool response:
       <tool_response>
       {"name": "tool_name", "content": {...}}
       </tool_response>

     Variables:
       {{TOOL_DEFINITIONS}}  — JSON array of tool definitions
     ============================================================ -->

<!-- This file documents the custom tool definitions for the agent.
     The Hermes runtime auto-registers built-in tools (terminal, file, web, etc.).
     Only custom/domain-specific tools need explicit definition here.

     These definitions can be:
     1. Loaded by a custom tool registry script
     2. Injected into the system prompt via AGENTS.md
     3. Registered as MCP server tools in config.yaml -->

[
{{TOOL_DEFINITIONS}}
]

<!-- TOOL DEFINITION FORMAT REFERENCE:
     Each tool follows this schema:

     {
       "type": "function",
       "function": {
         "name": "tool_identifier",
         "description": "What the tool does and when to use it.",
         "parameters": {
           "type": "object",
           "properties": {
             "param_name": {
               "type": "string|number|boolean|array|object",
               "description": "What this parameter controls"
             }
           },
           "required": ["param_name"]
         }
       }
     }

     TOOL CALL FORMAT (model output):
     <tool_call>
     {"name": "tool_identifier", "arguments": {"param_name": "value"}}
     </tool_call>

     TOOL RESPONSE FORMAT (injected as tool role):
     <tool_response>
     {"name": "tool_identifier", "content": {"result_key": "result_value"}}
     </tool_response>
-->
