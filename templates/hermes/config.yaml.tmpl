<!-- ============================================================
     HERMES AGENT — config.yaml
     Generated by ASK (Agent Setup Kit)

     Runtime configuration for the Hermes agent.
     Placed at ~/.hermes/config.yaml or managed per-project.

     Variables:
       {{MODEL_PROVIDER}}          — LLM provider (anthropic, openrouter, etc.)
       {{MODEL_NAME}}              — Model identifier
       {{FALLBACK_MODEL_CONFIG}}   — YAML block for fallback model (or comment)
       {{MEMORY_ENABLED}}          — true/false
       {{USER_PROFILE_ENABLED}}    — true/false
       {{MEMORY_CHAR_LIMIT}}       — Max chars for MEMORY.md (default: 2200)
       {{USER_CHAR_LIMIT}}         — Max chars for USER.md (default: 1375)
       {{MAX_TURNS}}               — Max iterations per turn (default: 90)
       {{REASONING_EFFORT}}        — Reasoning level (high, medium, low)
       {{APPROVAL_MODE}}           — ask, smart, or off
       {{TERMINAL_BACKEND}}        — local, docker, ssh, etc.
       {{TERMINAL_TIMEOUT}}        — Command timeout in seconds
       {{TERMINAL_EXTRA_CONFIG}}   — Additional terminal YAML
       {{COMPRESSION_ENABLED}}     — true/false
       {{COMPRESSION_THRESHOLD}}   — Float (e.g., 0.50)
       {{TOOL_PROGRESS}}           — off, new, all, verbose
       {{SKIN}}                    — Terminal skin name
       {{PERSONALITY_PRESET}}      — Built-in preset name (or empty)
       {{STREAMING_ENABLED}}       — true/false
       {{SHOW_REASONING}}          — true/false
       {{EXTRA_CONFIG}}            — Additional YAML sections
     ============================================================ -->

# Hermes Agent Configuration — {{AGENT_NAME}}
# Generated by ASK

model:
  provider: "{{MODEL_PROVIDER}}"
  default: "{{MODEL_NAME}}"

# Fallback model (optional — used when primary is unavailable)
{{FALLBACK_MODEL_CONFIG}}

memory:
  memory_enabled: {{MEMORY_ENABLED}}
  user_profile_enabled: {{USER_PROFILE_ENABLED}}
  memory_char_limit: {{MEMORY_CHAR_LIMIT}}
  user_char_limit: {{USER_CHAR_LIMIT}}

agent:
  max_turns: {{MAX_TURNS}}
  reasoning_effort: "{{REASONING_EFFORT}}"

approval_mode: {{APPROVAL_MODE}}

terminal:
  backend: {{TERMINAL_BACKEND}}
  timeout: {{TERMINAL_TIMEOUT}}
{{TERMINAL_EXTRA_CONFIG}}

compression:
  enabled: {{COMPRESSION_ENABLED}}
  threshold: {{COMPRESSION_THRESHOLD}}

display:
  tool_progress: {{TOOL_PROGRESS}}
  skin: {{SKIN}}
  personality: "{{PERSONALITY_PRESET}}"
  streaming: {{STREAMING_ENABLED}}
  show_reasoning: {{SHOW_REASONING}}

{{EXTRA_CONFIG}}
