#!/usr/bin/env bash
# Setup script for {{AGENT_NAME}} — Hermes Agent
# Generated by ASK

set -euo pipefail

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
AGENT_DIR="{{AGENT_OUTPUT_DIR}}"

echo "=== Setting up {{AGENT_NAME}} ==="

# 1. Copy config (backup existing)
if [ -f "$HERMES_HOME/config.yaml" ]; then
  cp "$HERMES_HOME/config.yaml" "$HERMES_HOME/config.yaml.bak"
  echo "Backed up existing config.yaml"
fi
cp "$AGENT_DIR/config.yaml" "$HERMES_HOME/config.yaml"
echo "Installed config.yaml"

# 2. Install SOUL.md (global fallback)
cp "$AGENT_DIR/SOUL.md" "$HERMES_HOME/SOUL.md"
echo "Installed SOUL.md"

# 3. Pre-load memory
mkdir -p "$HERMES_HOME/memories"
cp "$AGENT_DIR/memories/MEMORY.md" "$HERMES_HOME/memories/MEMORY.md"
cp "$AGENT_DIR/memories/USER.md" "$HERMES_HOME/memories/USER.md"
echo "Pre-loaded memory files"

# 4. Install skills
{{SKILLS_INSTALL_COMMANDS}}

# 5. Place AGENTS.md in working directory
echo "Place AGENTS.md in your project working directory:"
echo "  cp $AGENT_DIR/AGENTS.md /path/to/your/project/"

echo ""
echo "=== Setup complete ==="
echo "Run 'hermes' from your project directory to start."


