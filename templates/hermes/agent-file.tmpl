{{TOOL_DEFINITIONS}}
]

<!-- TOOL DEFINITION FORMAT REFERENCE:
     Each tool follows this schema:

     {
       "type": "function",
       "function": {
         "name": "tool_identifier",
         "description": "What the tool does and when to use it.",
         "parameters": {
           "type": "object",
           "properties": {
             "param_name": {
               "type": "string|number|boolean|array|object",
               "description": "What this parameter controls"
             }
           },
           "required": ["param_name"]
         }
       }
     }

     TOOL CALL FORMAT (model output):
     <tool_call>
     {"name": "tool_identifier", "arguments": {"param_name": "value"}}
     </tool_call>

     TOOL RESPONSE FORMAT (injected as tool role):
     <tool_response>
     {"name": "tool_identifier", "content": {"result_key": "result_value"}}
     </tool_response>
-->


