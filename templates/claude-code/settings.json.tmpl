{
  "_comment": "ASK Template: Claude Code settings.json — Generated by ASK (Agent Setup Kit)",
  "_variables": {
    "AGENT_SLUG": "Lowercase agent identifier, used in command prefixes and paths",
    "ALLOWED_BASH_COMMANDS": "Block array — each entry is a separate Bash permission (e.g., 'npm run *', 'git *')",
    "ALLOWED_FILE_EDIT_PATTERNS": "Block array — glob patterns for files the agent may edit (e.g., 'src/**/*.ts')",
    "ALLOWED_FILE_READ_PATTERNS": "Block array — glob patterns for files the agent may read",
    "DENIED_BASH_COMMANDS": "Block array — Bash commands the agent must never run",
    "DENIED_FILE_PATTERNS": "Block array — glob patterns for files the agent must never touch (e.g., '.env')",
    "ALLOWED_MCP_TOOLS": "Block array — MCP tool patterns the agent may use (e.g., 'mcp__slack__*')",
    "DENIED_MCP_TOOLS": "Block array — MCP tool patterns the agent must never use",
    "SESSION_START_HOOK": "Command to run at session start (e.g., load memory, check state)",
    "POST_TOOL_HOOK": "Command to run after each tool use (e.g., context monitoring)",
    "STATUS_LINE_COMMAND": "Command for the status line display"
  },

  "permissions": {
    "allow": [
      {{#ALLOWED_BASH_COMMANDS}}
      "Bash({{COMMAND}})",
      {{/ALLOWED_BASH_COMMANDS}}
      {{#ALLOWED_FILE_READ_PATTERNS}}
      "Read({{PATTERN}})",
      {{/ALLOWED_FILE_READ_PATTERNS}}
      {{#ALLOWED_FILE_EDIT_PATTERNS}}
      "Edit({{PATTERN}})",
      "Write({{PATTERN}})",
      {{/ALLOWED_FILE_EDIT_PATTERNS}}
      "Glob",
      "Grep"
      {{#ALLOWED_MCP_TOOLS}}
      ,"{{MCP_TOOL}}"
      {{/ALLOWED_MCP_TOOLS}}
    ],
    "deny": [
      {{#DENIED_BASH_COMMANDS}}
      "Bash({{COMMAND}})",
      {{/DENIED_BASH_COMMANDS}}
      {{#DENIED_FILE_PATTERNS}}
      "Read({{PATTERN}})",
      "Edit({{PATTERN}})",
      "Write({{PATTERN}})",
      {{/DENIED_FILE_PATTERNS}}
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git reset --hard)"
      {{#DENIED_MCP_TOOLS}}
      ,"{{MCP_TOOL}}"
      {{/DENIED_MCP_TOOLS}}
    ]
  },

  "_permissions_note": "Each permission must be a separate array entry. Use {{#ALLOWED_BASH_COMMANDS}} block to iterate over commands. Example input: [{COMMAND: 'npm run *'}, {COMMAND: 'git *'}] produces 'Bash(npm run *)', 'Bash(git *)' as separate entries. The same pattern applies to file patterns and MCP tools. When populating this template, ensure each permission resolves to its own string in the array — do NOT concatenate multiple permissions into a single entry.",

  "hooks": {
    {{#SESSION_START_HOOK}}
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{SESSION_START_HOOK}}"
          }
        ]
      }
    ],
    {{/SESSION_START_HOOK}}
    {{#POST_TOOL_HOOK}}
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{POST_TOOL_HOOK}}"
          }
        ]
      }
    ]
    {{/POST_TOOL_HOOK}}
  },

  {{#STATUS_LINE_COMMAND}}
  "statusLine": {
    "type": "command",
    "command": "{{STATUS_LINE_COMMAND}}"
  },
  {{/STATUS_LINE_COMMAND}}

  "skipDangerousModePermissionPrompt": false
}
