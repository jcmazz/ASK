# OpenClaw Agent Configuration — {{AGENT_DISPLAY_NAME}}
# Generated by ASK (Agent Setup Kit)

# ============================================================
# RUNTIME CONFIGURATION
# This file maps to ~/.openclaw/openclaw.json or can be used
# as a reference for manual configuration via `openclaw agents add`.
#
# Source: Discovery (Block C: model, runtime, integrations)
#         Architecture (Section 5: integrations, Section 6: model selection)
#
# Variables:
#   {{AGENT_SLUG}}               — Lowercase agent identifier
#   {{AGENT_DISPLAY_NAME}}       — Display name of the agent
#   {{AGENT_VERSION}}            — Agent version (semver)
#   {{AGENT_DESCRIPTION}}        — Brief description of the agent
#   {{MODEL_PROVIDER}}           — LLM provider (e.g., "anthropic")
#   {{MODEL_PRIMARY}}            — Primary model (e.g., "anthropic/claude-sonnet-4-6")
#   {{MODEL_SECONDARY}}          — Fallback/secondary model (optional)
#   {{MODEL_TEMPERATURE}}        — Temperature for generation (0.0-1.0)
#   {{MODEL_MAX_TOKENS}}         — Max output tokens per response
#   {{WORKSPACE_PATH}}           — Absolute path to agent workspace
#   {{HEARTBEAT_INTERVAL}}       — Heartbeat cycle in minutes (default: 30)
#   {{MEMORY_VAULT_PATH}}        — Path to deep knowledge vault
#   {{EMBEDDINGS_PROVIDER}}      — Embeddings provider (local, openai, gemini, none)
#   {{EMBEDDINGS_MODEL}}         — Embeddings model identifier
#   {{DISCORD_GUILD_ID}}         — Discord server ID (if applicable)
#   {{DISCORD_CHANNELS}}         — Discord channel routing config
#   {{SLACK_WORKSPACE}}          — Slack workspace ID (if applicable)
#   {{SLACK_CHANNELS}}           — Slack channel routing config
#   {{SKILLS_LIST}}              — List of skills to register
#   {{DAILY_LOG_PATH}}           — Path for daily log files
# ============================================================

# --- Agent Metadata ---

agent:
  name: "{{AGENT_SLUG}}"
  display_name: "{{AGENT_DISPLAY_NAME}}"
  version: "{{AGENT_VERSION}}"
  description: "{{AGENT_DESCRIPTION}}"

# --- Model Configuration ---

model:
  primary: "{{MODEL_PRIMARY}}"
{{#MODEL_SECONDARY}}
  secondary: "{{MODEL_SECONDARY}}"
{{/MODEL_SECONDARY}}
  temperature: {{MODEL_TEMPERATURE}}
  max_tokens: {{MODEL_MAX_TOKENS}}

# --- Workspace ---

workspace: "{{WORKSPACE_PATH}}"

# Default: ~/.openclaw/agents/{{AGENT_SLUG}}/workspace
# The workspace contains SOUL.md, IDENTITY.md, USER.md, TOOLS.md,
# AGENTS.md, HEARTBEAT.md, MEMORY.md, and the memory/ directory.

# --- Heartbeat ---

heartbeat:
  enabled: {{#HAS_HEARTBEAT}}true{{/HAS_HEARTBEAT}}{{^HAS_HEARTBEAT}}false{{/HAS_HEARTBEAT}}
  interval_minutes: {{HEARTBEAT_INTERVAL}}
  # Default: 30 minutes. Set to 0 or remove to disable.

# --- Memory Configuration ---

memory:
  daily_log_path: "{{DAILY_LOG_PATH}}"
  # Default: {{WORKSPACE_PATH}}/memory/
  vault_path: "{{MEMORY_VAULT_PATH}}"
  # Deep knowledge / reference documents path
{{#EMBEDDINGS_PROVIDER}}
  embeddings:
    provider: "{{EMBEDDINGS_PROVIDER}}"
    model: "{{EMBEDDINGS_MODEL}}"
    storage: "{{WORKSPACE_PATH}}/memory/.embeddings/"
{{/EMBEDDINGS_PROVIDER}}
{{^EMBEDDINGS_PROVIDER}}
  # embeddings: not configured (file-based memory only)
{{/EMBEDDINGS_PROVIDER}}

# --- Channel Routing ---
# Assigns the agent to specific communication channels.
# Agents only respond in channels where they are explicitly allowed.

{{#HAS_DISCORD}}
channels:
  discord:
    guilds:
      "{{DISCORD_GUILD_ID}}":
        channels:
{{DISCORD_CHANNELS}}
{{/HAS_DISCORD}}

{{#HAS_SLACK}}
  slack:
    workspace: "{{SLACK_WORKSPACE}}"
    channels:
{{SLACK_CHANNELS}}
{{/HAS_SLACK}}

{{#HAS_CLI}}
  cli:
    enabled: true
{{/HAS_CLI}}

{{^HAS_DISCORD}}{{^HAS_SLACK}}
# channels: none configured (CLI-only agent)
{{/HAS_SLACK}}{{/HAS_DISCORD}}

# --- Skills ---
# Skills are shared tool definitions. Register them here so the agent
# can discover and use them at runtime.

{{#HAS_SKILLS}}
skills:
{{#SKILLS_LIST}}
  - name: "{{SKILL_NAME}}"
    path: "{{SKILL_PATH}}"
{{/SKILLS_LIST}}
{{/HAS_SKILLS}}
{{^HAS_SKILLS}}
# skills: none registered
{{/HAS_SKILLS}}

# --- Additional Configuration ---
# Add any runtime-specific overrides below.
# These are passed directly to the OpenClaw runtime.

{{EXTRA_CONFIG}}

# ============================================================
# OPENCLAW.JSON EQUIVALENT
#
# This YAML template maps to the following openclaw.json structure
# when registered via `openclaw agents add`:
#
# {
#   "agents": {
#     "named": {
#       "{{AGENT_SLUG}}": {
#         "model": { "primary": "{{MODEL_PRIMARY}}" },
#         "workspace": "{{WORKSPACE_PATH}}"
#       }
#     }
#   }
# }
#
# Channel routing is configured separately in the global openclaw.json.
# ============================================================
